# ----------------------------------------------------
BEGIN BOUNDERIES
# Boundary conditions
x_min r     # symmetry plane at x=0
x_max v     # vacuum at x=170
y_min v     # vacuum at y=0
y_max r     # symmetry plane at y=170
z_min v     # vacuum
z_max v     # vacuum

END BOUNDERIES

# ---------------------------------------------------
BEGIN MATERIALS
fuel_1              1
fuel_2              2
fuel_2_plus_rod     3
reflector           4
reflector_plus_rod  5

END MATERIALS

# ---------------------------------------------------
BEGIN MESH
# 1 cell per region: 9x9x19 mesh
# x_cells_per_region 1
# y_cells_per_region 1
# z_cells_per_region 1

# 2 cells per region, 1 for z: 18x18x19 mesh
x_cells_per_region 2
y_cells_per_region 2
z_cells_per_region 1

# Fine-mesh: 2 cells per region, 1 for z: 36x36x38 mesh
# x_cells_per_region 4
# y_cells_per_region 4
# z_cells_per_region 2

END MESH
