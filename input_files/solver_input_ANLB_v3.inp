XS_LIBRARY "ANLBH_p11_xs_lib.csv"

# ----------------------------------------------------
BEGIN GEOMETRY
# ANL Benchmark Problem 11
# Quarter-core symmetry:
#   x_min (x=0)   = symmetry plane  -> reflective
#   y_max (y=170) = symmetry plane  -> reflective
#   x_max (x=170) = vacuum boundary
#   y_min (y=0)   = vacuum boundary
#
# Assembly layout (9x9 regions):
#   Rows = x direction (row 0 = x_min = symmetry, row 8 = x_max = vacuum)
#   Cols = y direction (col 0 = y_min = vacuum,   col 8 = y_max = symmetry)

# Material IDs:
#   1=Fuel1, 2=Fuel2, 3=Fuel2+Rod, 4=Reflector, 5=Refl+Rod

assemblies  16
symmetry    4

# X: 10cm half-assembly at symmetry (x_min), then 8x 20cm assemblies
x_planes 0.0 10.0 30.0 50.0 70.0 90.0 110.0 130.0 150.0 170.0

# Y: 8x 20cm assemblies, then 10cm half-assembly at symmetry (y_max)
y_planes 0.0 20.0 40.0 60.0 80.0 100.0 120.0 140.0 160.0 170.0

# Uniform 20cm axial blocks
z_planes 0.0 20.0 40.0 60.0 80.0 100.0 120.0 140.0 160.0 180.0 200.0 220.0 240.0 260.0 280.0 300.0 320.0 340.0 360.0 380.0

